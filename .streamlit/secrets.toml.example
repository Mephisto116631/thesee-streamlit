# .streamlit/secrets.toml.example
# Pour tester EN LOCAL avec la même mécanique que Streamlit Cloud :
#   1. Copie ce fichier en .streamlit/secrets.toml (sans le .example)
#   2. Remplis tes vraies valeurs
#   3. .streamlit/secrets.toml est dans le .gitignore -> jamais pushé
#
# Sur STREAMLIT CLOUD : ne pas créer ce fichier dans le repo.
# Va plutôt dans : ton app > Settings > Secrets, et colle ce même contenu.

SUPABASE_URL = "https://xxxx.supabase.co"
SUPABASE_KEY = "ta_cle_anon_ou_service_role"
ALPHA_VANTAGE_KEY = "ta_cle_alpha_vantage"
